# Nib — Supabase config (Accounts + Cloud Sync, Phase A)
# Copy this file to `.env.local` (gitignored) and fill in your project values.
# Both vars are exposed to the client via Vite's `import.meta.env` — only the
# PUBLIC anon key belongs here, never the service-role/secret key.

# Your Supabase project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Your Supabase public anon key (safe to ship to the client)
VITE_SUPABASE_ANON_KEY=

# Hocuspocus WebSocket URL for Yjs cloud sync (Accounts + Cloud Sync, Phase B).
# Phase B runs a LOCAL server: `npx @hocuspocus/server` → ws://localhost:1234.
# Phase C points this at the Render-hosted Hocuspocus instance.
VITE_HOCUSPOCUS_URL=ws://localhost:1234

# -----------------------------------------------------------------------------
# Hocuspocus server env (server/ only, NEVER expose to the client)
# Used by the self-hosted Hocuspocus server (server/src/). Set these in Render's
# Environment Variables, not in the Vite client .env.local.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_KEY=   # service_role key — bypasses RLS; NEVER commit or expose to client
SUPABASE_JWT_SECRET=    # Supabase → Project Settings → Auth → JWT Settings → JWT Secret
PORT=3000
